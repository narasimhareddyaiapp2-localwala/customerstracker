  "main": "node_modules/expo/AppEntry.js",
  "homepage": "https://NarasimhaProcess.github.io/location-tracker-mobile",
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "eject": "expo eject",
    "predeploy": "npx expo export --platform web && touch dist/.nojekyll && sed -i 's|src=\"/|src=\"/location-tracker-mobile/|g' dist/index.html && sed -i 's|href=\"/|href=\"/location-tracker-mobile/|g' dist/index.html",
    "deploy": "gh-pages -d dist --dotfiles"
  },
